# AI Configuration
# Get your API key from OpenAI or a compatible provider (DeepSeek, etc.)
VITE_AI_API_KEY=sk-your-api-key-here

# Base URL (optional)
# Defaults to https://api.openai.com/v1 if not set
# For DeepSeek: https://api.deepseek.com/v1
# For Moonshot: https://api.moonshot.cn/v1
VITE_AI_BASE_URL=https://api.openai.com/v1

# Model Name
# e.g. gpt-4o, gpt-3.5-turbo, deepseek-chat
VITE_AI_MODEL=gpt-4o-mini
